<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.MoneroOne" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary brand color -->
        <item name="colorPrimary">@color/monero_orange</item>
        <item name="colorPrimaryDark">@color/monero_orange_dark</item>
        <item name="colorAccent">@color/monero_orange</item>

        <!-- Status bar -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>

        <!-- Edge to edge -->
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>

        <!-- Android 12+ Splash Screen (Dark Mode) -->
        <item name="android:windowSplashScreenBackground">#FF000000</item>
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="android:windowSplashScreenIconBackgroundColor">#FF000000</item>
    </style>
</resources>
